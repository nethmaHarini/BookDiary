<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/splash_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <!-- Radial gradient glow: radial-gradient(circle at center, rgba(17,82,212,0.15) 0%, transparent 70%) -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_splash_glow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Center content column -->
    <LinearLayout
        android:id="@+id/center_block"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.44">

        <!-- Logo: 128dp, logo.png -->
        <FrameLayout
            android:id="@+id/logo_container"
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:alpha="0"
            android:scaleX="0.7"
            android:scaleY="0.7"
            android:layout_marginBottom="32dp">

            <ImageView
                android:id="@+id/iv_book_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/cd_book_icon"
                android:src="@drawable/logo"
                android:scaleType="fitCenter" />

        </FrameLayout>

        <!-- Title: "Book Recommendation Diary" serif bold -->
        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:fontFamily="serif"
            android:gravity="center"
            android:letterSpacing="-0.02"
            android:text="@string/splash_title"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold"
            android:translationY="24dp" />

        <!-- Tagline: uppercase, wide tracking, slate-400 -->
        <TextView
            android:id="@+id/tv_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:alpha="0"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:letterSpacing="0.18"
            android:text="@string/splash_tagline"
            android:textAllCaps="true"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:translationY="16dp" />

        <!-- Progress bar: 192dp wide, 4dp tall -->
        <FrameLayout
            android:id="@+id/loading_container"
            android:layout_width="192dp"
            android:layout_height="4dp"
            android:layout_marginTop="64dp"
            android:alpha="0">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_progress_track" />

            <View
                android:id="@+id/progress_fill"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_progress_fill" />

        </FrameLayout>

    </LinearLayout>

    <!-- Footer: "CRAFTED FOR READERS" pinned to bottom -->
    <TextView
        android:id="@+id/tv_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:alpha="0"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.2"
        android:text="@string/splash_crafted"
        android:textAllCaps="true"
        android:textColor="#6B7280"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
